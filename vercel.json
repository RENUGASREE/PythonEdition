{
  "version": 2,
  "name": "python-edition-adaptive-learning",
  "buildCommand": "npm run build",
  "outputDirectory": "dist",
  "installCommand": "npm install",
  "framework": "vite",
  "routes": [
    {
      "src": "/api/(.*)",
      "dest": "$VERCEL_BACKEND_URL/api/$1"
    },
    {
      "src": "/(.*)",
      "dest": "/$1"
    }
  ],
  "deployed": "2025-04-12T22:57:00Z"
}
