{
  "version": 2,
  "name": "python-edition-adaptive-learning",
  "builds": [
    {
      "src": "package.json",
      "use": "@vercel/static-build",
      "config": {
        "distDir": "dist"
      }
    }
  ],
  "routes": [
    {
      "src": "/api/(.*)",
      "dest": "$VERCEL_BACKEND_URL/api/$1"
    },
    {
      "src": "/(.*)",
      "dest": "/$1"
    }
  ],
  "env": {
    "VITE_API_BASE_URL": "$VERCEL_BACKEND_URL/api"
  },
  "build": {
    "env": {
      "VITE_API_BASE_URL": "$VERCEL_BACKEND_URL/api"
    }
  }
}
